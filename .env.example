# Better Auth
BETTER_AUTH_SECRET=your_better_auth_secret_here
BETTER_AUTH_URL=http://localhost:3000

# Prisma / PostgreSQL
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# Social Providers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google Maps / Places
GOOGLE_MAPS_API_KEY=your_server_google_maps_api_key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_browser_google_maps_api_key

# DigitalOcean Spaces
SPACES_KEY=your_spaces_access_key
SPACES_SECRET=your_spaces_secret_key
SPACES_REGION=tor1
SPACES_ENDPOINT=https://tor1.digitaloceanspaces.com
SPACES_BUCKET=your_spaces_bucket_name

# Unsplash
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Groq
GROQ_API_KEY=your_groq_api_key
